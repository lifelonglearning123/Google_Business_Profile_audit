# =============================================================================
# Environment configuration
# =============================================================================
# This project supports multi-tenant deployment: one repo can power many
# Vercel projects, each with its own per-site config below. See
# docs/MULTI_TENANT_DEPLOY.md for the full setup guide.
# =============================================================================


# ────────────────────────────────────────────────────────────────────────────
# PER-SITE — set differently for each Vercel project / tenant
# ────────────────────────────────────────────────────────────────────────────

# Brand label shown in the page title, footer, and PDF cover.
# Each Vercel project sets this to its own white-label brand.
NEXT_PUBLIC_BRAND_NAME=GBP Audit

# Public — base URL of the deployed app. No trailing slash.
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public — agency contact for the mailto fallback CTA.
NEXT_PUBLIC_AGENCY_EMAIL=hello@yourdomain.com

# Public — Calendly (or any scheduling) URL for the strategy-call CTA.
# When set, the report's CTA becomes "Apply for a 30-min strategy call"
# and links here. When unset, falls back to the mailto above.
NEXT_PUBLIC_CALENDLY_URL=

# GHL inbound webhook URL (Settings → Workflows → Inbound Webhook trigger).
# Optional. If blank, the audit still runs and just logs a warning.
GHL_WEBHOOK_URL=


# ────────────────────────────────────────────────────────────────────────────
# SHARED — usually the same across every Vercel project (one billing account)
# ────────────────────────────────────────────────────────────────────────────

# Apify — sign up at https://apify.com and paste your token (raw, no quotes).
# Used by lib/apify.ts to call the compass/crawler-google-places Actor.
APIFY_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# DataForSEO — sign up at https://dataforseo.com ($1 free credit on signup).
# Used by the landing-page revenue-loss calculator (/api/loss-calc) for live
# UK keyword search-volume lookups. ~$0.0006 per submission.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# SerpAPI — legacy, kept only for rollback. lib/serpapi.ts is no longer
# imported by the audit route. Safe to leave blank.
SERPAPI_KEY=


# ────────────────────────────────────────────────────────────────────────────
# AUDIT STORAGE (per-site in production, file-based in dev)
# ────────────────────────────────────────────────────────────────────────────
# When you create a Vercel KV store and link it to the project, Vercel
# auto-injects KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN,
# and KV_URL. Don't set them manually — let Vercel manage them.
# Each Vercel project should have its OWN KV instance so audit data stays
# isolated between sites.
# In local dev, leave them blank: lib/store.ts falls back to .audits/ on disk.
