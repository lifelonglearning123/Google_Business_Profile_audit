# SerpAPI — sign up at https://serpapi.com and paste your key (raw, no quotes)
SERPAPI_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# GHL inbound webhook URL (Settings → Workflows → Inbound Webhook trigger).
# Optional. If blank, the audit still runs and just logs a warning.
GHL_WEBHOOK_URL=

# Public — agency contact for the "Talk to us" CTA in the report.
# NEXT_PUBLIC_ prefix exposes this to the browser, which is what we want.
NEXT_PUBLIC_AGENCY_EMAIL=hello@yourdomain.com

# Public — base URL of the deployed app. No trailing slash.
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
